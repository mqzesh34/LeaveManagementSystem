NODE_ENV=development

# Uygulama adresleri
CLIENT_URL=http://localhost:5173
AUTH_SERVICE_URL=http://auth_service:1001
SOCKET_SERVICE_URL=http://socket_service:1003

# Servis portları
AUTH_PORT=1001
MANAGEMENT_PORT=1002
SOCKET_PORT=1003

# Veritabanları
MONGO_URI=mongodb://mongodb:27017/leave_management
POSTGRES_USER=leave_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=leave_management
DB_HOST=postgres
DB_PORT=5432

# Güvenlik
JWT_SECRET=change_this_to_a_long_random_secret
SOCKET_SERVICE_TOKEN=change_this_to_a_private_service_token

# Vite istemci değişkenleri
VITE_API_DOMAIN=http://localhost
VITE_AUTH_SERVICE_PORT=1001
VITE_MANAGEMENT_SERVICE_PORT=1002
VITE_SOCKET_SERVICE_PORT=1003
